# Environment Variables Example
# Copy this file to .env and fill in your values

# App Settings
APP_NAME=AI Chat Platform
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=development

# Database - MongoDB Atlas
# Format: mongodb+srv://username:password@cluster.mongodb.net
MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net
MONGODB_DB_NAME=ai_chat_platform
MONGODB_MAX_POOL_SIZE=10
MONGODB_MIN_POOL_SIZE=1

# Huey Task Queue
HUEY_SQLITE_PATH=./huey.db

# Security
SECRET_KEY=your-secret-key-change-in-production
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=["*"]

# AI Services - Alibaba Cloud Bailian Platform
BAILIAN_API_KEY=sk-sp-2eaa1e1964a44dbca3384a7292e4c903
BAILIAN_BASE_URL=https://coding.dashscope.aliyuncs.com/v1
DEFAULT_MODEL=qwen3.5-plus
MAX_TOKENS=4096
DEFAULT_TEMPERATURE=0.7

# Supported Models
SUPPORTED_MODELS=["qwen3.5-plus","qwen3-max-2026-01-23","qwen3-coder-next","qwen3-coder-plus","glm-5","glm-4.7","kimi-k2.5","MiniMax-M2.5"]

# Alibaba Cloud Search Service (IQS)
# ⚠️ IMPORTANT: Set your API key here
ALIBABA_SEARCH_API_KEY=bxkz02_IucrtiIOgZ7xCCinParE5rFI2OWNmMjg1ZQ
ALIBABA_SEARCH_BASE_URL=https://iqs.cn-beijing.aliyuncs.com
ALIBABA_SEARCH_TIMEOUT=5

# Agent Settings
ENABLE_SEARCH_AGENT=true
SEARCH_MAX_RESULTS=5
AGENT_MAX_ITERATIONS=3

# File Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760